	measure 'Indicador % Custo de frete YoY' =
			
			VAR Custo_YoY = CALCULATE([Custo frete],
			DATEADD(dCalendario[Data],-1,YEAR)
			)
			VAR Percentual_YoY = IF(
			    HASONEVALUE(dCalendario[Ano]),
			    DIVIDE([Custo frete]-Custo_YoY,Custo_YoY,"N/A"),"N/A"
			    )
			VAR SETA = IF(Percentual_YoY>0, "▲ ",
			"▼ ")
			
			RETURN
			SETA & FORMAT(Percentual_YoY,"0.00%")
		lineageTag: f93b5e01-5bd3-4536-bd44-2d2855076afb

