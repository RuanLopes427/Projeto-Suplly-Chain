	measure '% Faturamento YoY' =
			
			VAR Faturamento_Atual = [Faturamento Total]
			VAR Faturamento_YoY = CALCULATE([Faturamento Total],
			DATEADD(dCalendario[Data],-1,YEAR))
			RETURN
			IF(
			    HASONEVALUE(dCalendario[Ano]),
			    DIVIDE(Faturamento_Atual-Faturamento_YoY,Faturamento_YoY,"N/A"),"N/A")
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 61c90edf-1073-43d7-baba-70d2c3bb9372

	measure 'Indicador Fat Atual VS anterior' =
			
			VAR seta = IF([% Faturamento YoY]>0,"▲ ", "▼ ")
			VAR Variacao = [% Faturamento YoY]
			RETURN
			seta &FORMAT(Variacao,"0.00%")
		lineageTag: 78762612-3cb2-42cf-a9b5-8ff60c6c77dd

	measure '% Lucro YoY' =
			
			VAR Lucro_Atual = [Lucro Total]
			VAR Lucro_YoY =CALCULATE([Lucro Total],
			DATEADD(dCalendario[Data],-1,YEAR))
			RETURN
			IF(
			    HASONEVALUE(dCalendario[Ano]),
			        DIVIDE(Lucro_Atual-Lucro_YoY,Lucro_YoY,"N/A"),"N/A")
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: c6c95ebb-b635-4f7f-8115-51f5d19b25d8

	measure 'Indicador Lucro Atual vs Anterior' =
			
			VAR seta = IF([% Lucro YoY]>0,"▲ ","▼ ")
