			RETURN
			seta & FORMAT(variacao,"0.00%")
		lineageTag: a4977e2d-8077-45e3-88fb-26c7cd21525f

	measure '% Entregas no Prazo' =
			
			VAR Quantiida_Entregues = COUNTX(FILTER(fVendas_Logistica,
			fVendas_Logistica[Status_Entrega] ="Entregue"),
			"")
			VAR Total_Vendas = [Total Vendas]
			RETURN
			Quantiida_Entregues/Total_Vendas
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 137d1d83-df21-41a1-acf1-5b1a1a17ea14

