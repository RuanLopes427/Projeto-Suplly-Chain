	measure '% Acumulado Clientes' =
			
			VAR FatClienteAtual =
			    CALCULATE( SUM( fVendas_Logistica[Valor_Venda] ) )
			
			VAR FatTotal =
			    CALCULATE(
			        SUM( fVendas_Logistica[Valor_Venda] ),
			        ALL( dClientes )
			    )
			
			VAR FatAcumulado =
			    CALCULATE(
			        SUM( fVendas_Logistica[Valor_Venda] ),
			        FILTER(
			            ALL( dClientes ),
			            CALCULATE( SUM( fVendas_Logistica[Valor_Venda] ) )
			                >= FatClienteAtual
			        )
			    )
			
			RETURN
			    DIVIDE( FatAcumulado, FatTotal, 0 )
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: c1635646-9f99-4c7e-a876-a743797ca429

