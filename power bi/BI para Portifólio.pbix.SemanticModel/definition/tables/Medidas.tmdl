			RETURN
			seta & FORMAT(Variacao,"0.00%")
		lineageTag: ebdf950e-c820-42ae-9197-32d4789b188f

	measure '% Total de Vendas YoY' = ```
			
			VAR Vendas_AnoAnterior = CALCULATE([Total Vendas],
			DATEADD(dCalendario[Data],-1,YEAR))
			VAR TotalVendasAtual = [Total Vendas]
			RETURN
			IF(
			    HASONEVALUE(dCalendario[Ano]),
			        DIVIDE(TotalVendasAtual-Vendas_AnoAnterior,Vendas_AnoAnterior,"N/A"),"N/A")
			
